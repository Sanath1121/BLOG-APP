# Root .gitignore for BLOG-APP

# Node
node_modules/

# Ignore node_modules only inside subfolders (explicit)
/frontend/node_modules/
/backend/node_modules/

# Environment files
.env
.env.*

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/

# Build output
dist/
build/

# Vite / npm artifacts
/.pnp
.pnp.js

# Coverage
coverage/

# Misc
.cache/
*.lock
